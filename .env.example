# Public site URL (booking links, copy-to-clipboard)
NEXT_PUBLIC_APP_URL=https://www.getgroomerflow.com

# NextAuth — local dev use http://localhost:3000 (see README)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

AUTH_SECRET=generate-with-openssl-rand-base64-32
# Legacy alias (optional)
NEXTAUTH_SECRET=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (optional) — Google Cloud OAuth client (Web)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://www.getgroomerflow.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — Resend https://resend.com (dev logs to console if unset)
RESEND_API_KEY=
EMAIL_FROM=GetGroomerFlow <bookings@getgroomerflow.com>
# Privacy / data export requests (shown on /privacy)
PRIVACY_CONTACT_EMAIL=privacy@getgroomerflow.com

# Vercel Cron — Vercel sends Authorization: Bearer <CRON_SECRET> automatically
CRON_SECRET=generate-with-openssl-rand-base64-32

# Stripe — booking deposits (platform account; manual capture hold)
# Dashboard: https://dashboard.stripe.com/apikeys
# Webhook endpoint: https://www.getgroomerflow.com/api/webhooks/stripe
#   Events: checkout.session.completed, checkout.session.expired
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BOOKING_DEPOSIT_CENTS=2000

# Lemon Squeezy — groomer subscriptions (MoR)
# Checkout URL from LS dashboard (include variant); custom groomer_id is appended in app
NEXT_PUBLIC_LEMON_SQUEEZY_CHECKOUT_URL=
LEMON_SQUEEZY_WEBHOOK_SECRET=
# Webhook endpoint: https://www.getgroomerflow.com/api/webhooks/lemon-squeezy
