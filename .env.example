# Public site URL (booking links, copy-to-clipboard)
NEXT_PUBLIC_APP_URL=https://getgroomerflow.com

# NextAuth — local dev use http://localhost:3000 (see README)
# Production uses .env.production → https://getgroomerflow.com
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

AUTH_SECRET=generate-with-openssl-rand-base64-32
# Legacy alias (optional)
NEXTAUTH_SECRET=

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth (optional) — add redirect: https://getgroomerflow.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — Resend https://resend.com (dev logs to console if unset)
RESEND_API_KEY=
EMAIL_FROM=GetGroomerFlow <bookings@getgroomerflow.com>

# Vercel Cron — protect /api/cron/reminders
CRON_SECRET=
